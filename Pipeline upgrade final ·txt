        "hook_cap_ms":      (int,   500,  3000),
        "tension_interval": (int,   1000, 5000),
        "core_interval":    (int,   2000, 8000),
        "shorts_scale":     (float, 0.30, 0.70),
    }

    def validate_adaptive_params(params: dict) -> dict:
        """Returns validated params. Falls back to defaults on any violation."""
        defaults = {k: v[1] for k, v in ADAPTIVE_SCHEMA.items()}
        for key, (typ, lo, hi) in ADAPTIVE_SCHEMA.items():
            val = params.get(key)
            if not isinstance(val, (int, float)) or not (lo <= val <= hi):
                logging.warning(
                    "adaptive_params[%s]=%r invalid -- using default %s",
                    key, val, defaults[key]
                )
                params[key] = defaults[key]
        return params

    def save_adaptive_params(params: dict, path):
        """Atomic write: temp file + rename prevents partial-write corruption."""
        tmp = path.with_suffix(".tmp")
        tmp.write_text(json.dumps(params, indent=2))
        tmp.replace(path)   # atomic on POSIX, near-atomic on Windows

    def load_adaptive_params(path) -> dict:
        if not path.exists():
            return {k: v[1] for k, v in ADAPTIVE_SCHEMA.items()}
        try:
            raw = json.loads(path.read_text())
            return validate_adaptive_params(raw)
        except json.JSONDecodeError:
            logging.error("adaptive_params.json is corrupt -- using defaults")
            return {k: v[1] for k, v in ADAPTIVE_SCHEMA.items()}

================================================================================
MISSING GAP 3 — VELOCITY QUEUE HAS NO TTL
================================================================================

PROBLEM
--------
Seeds written to logs/velocity_queue.json after a viral video are consumed
at "highest priority" on the next pipeline run. There is no expiry (TTL).
A topic trending 3 weeks ago is not a high-priority seed today.
Stale seeds displace genuinely trending current content indefinitely.

SOLUTION — 72-hour TTL on all velocity queue entries

In Step 14 (update_velocity_queue):

    def write_velocity_seeds(seeds: list):
        now = time.time()
        queue_path = LOG_DIR / "velocity_queue.json"
        existing = (json.loads(queue_path.read_text())
                    if queue_path.exists() else [])
        # Evict expired entries (TTL = 72 hours)
        fresh = [e for e in existing if now - e["ts"] < 72 * 3600]
        fresh += [{"seed": s, "ts": now} for s in seeds]
        queue_path.write_text(json.dumps(fresh, indent=2))

In Step 1 (topic_selector):

    def read_velocity_seeds() -> list:
        now = time.time()
        queue_path = LOG_DIR / "velocity_queue.json"
        if not queue_path.exists():
            return []
        entries = json.loads(queue_path.read_text())
        # Only return seeds younger than 72 hours
        return [e["seed"] for e in entries if now - e["ts"] < 72 * 3600]

================================================================================
MISSING GAP 4 — PEAK-HOUR SLEEP BURNS RUNNER MINUTES
================================================================================

PROBLEM
--------
Step 13 (uploader.py) sleeps up to 25 minutes to align upload with peak
audience hours. GitHub Actions bills runner minutes during sleep.

At 3 runs/day: up to 75 wasted minutes/day = ~2,250 minutes/month.
GitHub Actions free tier = 2,000 minutes/month.
This single sleep alone can exhaust the entire free quota.

SOLUTION — Move sleep outside the runner

Option A (simplest — static peak hours):
Remove the in-process sleep entirely.
Schedule upload as a separate GitHub Actions workflow triggered by the render
job's completion via workflow_run, using a cron offset targeting peak hour.

    # .github/workflows/upload_trigger.yml
    on:
      workflow_run:
        workflows: ["MindBlownFacts Video Pipeline"]
        types: [completed]

    jobs:
      upload:
        runs-on: ubuntu-latest
        if: ${{ github.event.workflow_run.conclusion == 'success' }}
        steps:
          - uses: actions/checkout@v4
          - name: Upload to YouTube
            run: python pipeline/scripts/uploader.py --skip-sleep

Option B (dynamic peak hours):
Remove in-process sleep. At end of render, write completed video path and
target upload timestamp to logs/pending_upload.json.
Add a lightweight cron job (every 5 min) that checks pending_upload.json
and triggers upload only when target time is reached.
Runner minutes consumed per check: under 1 minute.

    # End of render pipeline — write pending upload record
    pending = {
        "video_path": str(output_path),
        "target_ts":  peak_hour_timestamp,   # from existing peak_hours.json
        "created_ts": time.time(),
    }
    (LOG_DIR / "pending_upload.json").write_text(json.dumps(pending, indent=2))

    # Separate lightweight uploader job (runs every 5 min via cron)
    pending_path = LOG_DIR / "pending_upload.json"
    if pending_path.exists():
        record = json.loads(pending_path.read_text())
        if time.time() >= record["target_ts"]:
            upload(record["video_path"])
            pending_path.unlink()   # clear after upload

